# Required: At least one AI provider for Notionbook
# Get keys from: https://console.anthropic.com/ | https://aistudio.google.com/apikey | https://console.groq.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional: Notion OAuth (uses dynamic registration if not set)
# NOTION_OAUTH_CLIENT_ID=
# NOTION_OAUTH_CLIENT_SECRET=

# Optional: Server port (default: 3001)
PORT=3001
