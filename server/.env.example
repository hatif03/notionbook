# LLM keys (optional if using BYOK from the Chrome extension popup)
# The server uses: request body llmApiKey first, then these env vars per provider.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# Gemini / Google AI Studio
GEMINI_API_KEY=
# Alias: GOOGLE_AI_API_KEY=

# Optional: Server port (default: 3001)
PORT=3001

# Public base URL of this server (used for Notion page cover images from screenshots)
# Example: http://localhost:3001 or your forwarded HTTPS URL
BASE_URL=http://localhost:3001

# Notion MCP OAuth — must match the redirect URL configured at the authorization server
# Local: http://localhost:3001/auth/notion/callback
NOTION_OAUTH_REDIRECT_URI=http://localhost:3001/auth/notion/callback

# Optional: if set, extension and clients must send header X-API-Key: <value>
EXTENSION_API_KEY=
